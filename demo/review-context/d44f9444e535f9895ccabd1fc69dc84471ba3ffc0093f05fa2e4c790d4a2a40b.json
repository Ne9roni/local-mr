{"lines":["#!/usr/bin/env node","","import crypto from \"node:crypto\";","import fs from \"node:fs/promises\";","import http from \"node:http\";","import os from \"node:os\";","import path from \"node:path\";","import { promisify } from \"node:util\";","import { brotliCompress, constants as zlibConstants } from \"node:zlib\";","","import {","    buildComparisonPatch,","    buildFileContext,","    buildFilePreview,","    buildVersionModel,","    inspectRepositoryState,","    normalizeSelection,","} from \"./version-model.mjs\";","import { patchSummary, renderDiffDocument, splitRenderedReview } from \"./review-render.mjs\";","","const brotliCompressAsync = promisify(brotliCompress);","","const parseArguments = (values) => {","    const options = {};","    for (let index = 0; index < values.length; index += 2) {","        const key = values[index];","        const value = values[index + 1];","        if (!key?.startsWith(\"--\") || value === undefined) {","            throw new Error(`Invalid argument: ${key || \"<missing>\"}`);","        }","        options[key.slice(2)] = value;","    }","    return options;","};","","const htmlEscape = (value) => String(value)","    .replaceAll(\"&\", \"&amp;\")","    .replaceAll(\"<\", \"&lt;\")","    .replaceAll(\">\", \"&gt;\")","    .replaceAll('\"', \"&quot;\")","    .replaceAll(\"'\", \"&#39;\");","","const safeJson = (value) => JSON.stringify(value)","    .replaceAll(\"<\", \"\\\\u003c\")","    .replaceAll(\">\", \"\\\\u003e\")","    .replaceAll(\"&\", \"\\\\u0026\");","","const clientModel = ({","    model,","    selection,","    reviewUrl,","    rootUrl,","    patchId,","    filePatchIds,","    files,","    readStateId,","}) => ({","    reviewUrl,","    reviewDataUrl: `${rootUrl}/review-data`,","    fragmentUrl: `${rootUrl}/diff-file`,","    contextUrl: `${rootUrl}/diff-context`,","    previewUrl: `${rootUrl}/file`,","    readStateUrl: `${rootUrl}/read-state/${readStateId}`,","    assets: {","        marked: `${rootUrl}/assets/marked.js`,","        dompurify: `${rootUrl}/assets/dompurify.js`,","        mermaid: `${rootUrl}/assets/mermaid.js`,","    },","    patchId,","    filePatchIds,","    files,","    mode: selection.mode,","    selection,","    branchName: model.branchName,","    targetRef: model.targetRef,","    dirty: model.dirty,","    pushVersions: model.pushVersions.map((version) => ({","        kind: version.kind,","        virtual: Boolean(version.virtual),","        value: version.value,","        label: version.label,","        description: version.description,","        latest: Boolean(version.latest),","        shortSha: version.sha.slice(0, 8),","    })),","    commits: model.commits.map((commit) => ({","        kind: commit.kind || \"commit\",","        virtual: Boolean(commit.virtual),","        sha: commit.sha,","        shortSha: commit.shortSha,","        subject: commit.subject,","        author: commit.author,","        dateLabel: commit.dateLabel,","    })),","});","","const injectReviewUi = ({ html, fragment, versionData }) => {","    const injection = [","        `<script id=\"local-mr-version-data\" type=\"application/json\">${safeJson(versionData)}</script>`,","        fragment,","    ].join(\"\\n\");","    if (!html.includes(\"</head>\")) throw new Error(\"diff2html output does not contain </head>\");","    return html.replace(\"</head>\", `${injection}\\n</head>`);","};","","const errorPage = (error) => `<!doctype html>","<html lang=\"en\">","<head><meta charset=\"utf-8\"><title>Local MR error</title></head>","<body style=\"font:14px/1.6 system-ui;padding:32px;color:#292929\">","<h1 style=\"font-size:18px\">Local MR could not generate this comparison</h1>","<pre style=\"white-space:pre-wrap;background:#f7f8fa;padding:16px;border-radius:6px\">${htmlEscape(error.stack || error.message)}</pre>","</body></html>`;","","const options = parseArguments(process.argv.slice(2));","const required = [\"repo\", \"target\", \"style\", \"color\", \"fragment\", \"ready\"];","for (const name of required) {","    if (!options[name]) throw new Error(`Missing --${name}`);","}","","const repoRoot = path.resolve(options.repo);","const reviewFragment = await fs.readFile(options.fragment, \"utf8\");","const runtimeRoot = await (async () => {","    const candidates = [new URL(\"./\", import.meta.url), new URL(\"../\", import.meta.url)];","    for (const candidate of candidates) {","        try {","            await fs.access(new URL(\"node_modules/diff2html/package.json\", candidate));","            return candidate;","        } catch {}","    }","    throw new Error(\"local-mr dependencies are missing; run npm ci or reinstall local-mr\");","})();","const diff2htmlStylesheet = await fs.readFile(","    new URL(\"node_modules/diff2html/bundles/css/diff2html.min.css\", runtimeRoot),","    \"utf8\",",");","const token = crypto.randomBytes(18).toString(\"base64url\");","const assetFiles = new Map([","    [\"marked.js\", new URL(\"node_modules/marked/lib/marked.umd.js\", runtimeRoot)],","    [\"dompurify.js\", new URL(\"node_modules/dompurify/dist/purify.min.js\", runtimeRoot)],","    [\"mermaid.js\", new URL(\"node_modules/mermaid/dist/mermaid.min.js\", runtimeRoot)],","]);","const assetCache = new Map();","const loadAsset = async (assetName, useBrotli) => {","    const cacheKey = `${assetName}:${useBrotli ? \"br\" : \"identity\"}`;","    if (assetCache.has(cacheKey)) return assetCache.get(cacheKey);","    const identityKey = `${assetName}:identity`;","    const source = assetCache.get(identityKey) || await fs.readFile(assetFiles.get(assetName));","    const content = useBrotli","        ? await brotliCompressAsync(source, {","            params: { [zlibConstants.BROTLI_PARAM_QUALITY]: 5 },","        })","        : source;","    if (!useBrotli) assetCache.set(identityKey, source);","    assetCache.set(cacheKey, content);","    return content;","};","const maximumCacheEntries = 8;","const maximumCacheBytes = 64 * 1024 * 1024;","const maximumModelCacheEntries = 4;","const maximumPatchCacheEntries = 16;","const maximumPatchCacheBytes = 64 * 1024 * 1024;","const maximumFragmentCacheEntries = 512;","const createLruCache = ({ maximumEntries, maximumBytes = Infinity, maximumEntryBytes = Infinity, sizeOf }) => {","    const entries = new Map();","    let bytes = 0;","    return {","        get(key) {","            const entry = entries.get(key);","            if (!entry) return undefined;","            entries.delete(key);","            entries.set(key, entry);","            return entry.value;","        },","        set(key, value) {","            const valueBytes = sizeOf(value);","            if (valueBytes > maximumEntryBytes || valueBytes > maximumBytes) return;","            const existing = entries.get(key);","            if (existing) {","                bytes -= existing.bytes;","                entries.delete(key);","            }","            while (entries.size > 0 && (","                entries.size >= maximumEntries","                || bytes + valueBytes > maximumBytes","            )) {","                const oldestKey = entries.keys().next().value;","                bytes -= entries.get(oldestKey).bytes;","                entries.delete(oldestKey);","            }","            entries.set(key, { value, bytes: valueBytes });","            bytes += valueBytes;","        },","    };","};","const pageCache = createLruCache({","    maximumEntries: maximumCacheEntries,","    maximumBytes: maximumCacheBytes,","    maximumEntryBytes: maximumCacheBytes,","    sizeOf: (page) => Buffer.byteLength(page.html) + Buffer.byteLength(page.diffHtml),","});","const modelCache = createLruCache({","    maximumEntries: maximumModelCacheEntries,","    sizeOf: () => 1,","});","const patchCache = createLruCache({","    maximumEntries: maximumPatchCacheEntries,","    maximumBytes: maximumPatchCacheBytes,","    maximumEntryBytes: maximumPatchCacheBytes,","    sizeOf: (patchText) => Buffer.byteLength(patchText),","});","const fragmentCache = createLruCache({","    maximumEntries: maximumFragmentCacheEntries,","    maximumBytes: maximumCacheBytes,","    maximumEntryBytes: maximumCacheBytes,","    sizeOf: (html) => Buffer.byteLength(html),","});","const renderJobs = new Map();","const modelJobs = new Map();","const patchJobs = new Map();","const readStateDirectory = path.join(","    process.env.XDG_STATE_HOME || path.join(os.homedir(), \".local\", \"state\"),","    \"local-mr\",","    \"read-state\",",");","const idleMilliseconds = Math.max(1, Number(options[\"idle-minutes\"] || 480)) * 60 * 1000;","let idleTimer;","let server;","","const getVersionModel = async (repositoryState) => {","    const cached = modelCache.get(repositoryState.modelKey);","    if (cached) return { model: cached, cacheStatus: \"hit\" };","    let job = modelJobs.get(repositoryState.modelKey);","    if (!job) {","        job = buildVersionModel({","            repoRoot,","            targetRef: options.target,","            repositoryState,","        });","        modelJobs.set(repositoryState.modelKey, job);","    }","    try {","        const model = await job;","        modelCache.set(repositoryState.modelKey, model);","        return { model, cacheStatus: \"miss\" };","    } finally {","        if (modelJobs.get(repositoryState.modelKey) === job) {","            modelJobs.delete(repositoryState.modelKey);","        }","    }","};","","const getComparisonPatch = async ({ model, repositoryState, selection }) => {","    const worktreeKey = selection.to === \"worktree\" ? repositoryState.worktreeKey : \"committed\";","    const key = crypto.createHash(\"sha256\")","        .update(model.base.sha)","        .update(\"\\0\")","        .update(JSON.stringify(selection))","        .update(\"\\0\")","        .update(worktreeKey)","        .digest(\"hex\");","    const cached = patchCache.get(key);","    if (cached) return { patchText: cached, cacheStatus: \"hit\" };","    let job = patchJobs.get(key);","    if (!job) {","        job = buildComparisonPatch({ repoRoot, model, selection });","        patchJobs.set(key, job);","    }","    try {","        const patchText = await job;","        patchCache.set(key, patchText);","        return { patchText, cacheStatus: \"miss\" };","    } finally {","        if (patchJobs.get(key) === job) patchJobs.delete(key);","    }","};","","const decodeGitPath = (value) => {","    if (!value.startsWith('\"') || !value.endsWith('\"')) return value;","    const input = value.slice(1, -1);","    const chunks = [];","    for (let index = 0; index < input.length; index += 1) {","        if (input[index] !== \"\\\\\") {","            chunks.push(Buffer.from(input[index]));","            continue;","        }","        const octal = input.slice(index + 1).match(/^[0-7]{3}/)?.[0];","        if (octal) {","            chunks.push(Buffer.from([Number.parseInt(octal, 8)]));","            index += 3;","            continue;","        }","        index += 1;","        const escaped = { n: \"\\n\", r: \"\\r\", t: \"\\t\", b: \"\\b\", f: \"\\f\" }[input[index]]","            || input[index];","        chunks.push(Buffer.from(escaped));","    }","    return Buffer.concat(chunks).toString(\"utf8\");","};","","const patchPath = (section, prefix, stripPrefix = false) => {","    const line = section.match(new RegExp(`^${prefix} (.+)$`, \"m\"))?.[1] || \"\";","    const decoded = decodeGitPath(line.trim());","    if (decoded === \"/dev/null\") return \"\";","    return stripPrefix ? decoded.replace(/^[ab]\\//, \"\") : decoded;","};","","const renamedDisplayPath = (oldPath, newPath) => {","    const oldDirectory = path.posix.dirname(oldPath);","    const newDirectory = path.posix.dirname(newPath);","    if (oldDirectory === newDirectory) {","        const directory = oldDirectory === \".\" ? \"\" : `${oldDirectory}/`;","        return `${directory}{${path.posix.basename(oldPath)} → ${path.posix.basename(newPath)}}`;","    }","    return `${oldPath} → ${newPath}`;","};","","const buildFilePatchData = (patchText) => {","    const filePatchIds = {};","    const files = [];","    const sections = patchText.split(/(?=^diff --git )/m).filter((section) => section.startsWith(\"diff --git \"));","    sections.forEach((section) => {","        const renamedFrom = patchPath(section, \"rename from\");","        const renamedTo = patchPath(section, \"rename to\");","        const oldPath = renamedFrom || patchPath(section, \"---\", true);","        const newPath = renamedTo || patchPath(section, \"\\\\+\\\\+\\\\+\", true);","        const id = crypto.createHash(\"sha256\").update(section).digest(\"hex\");","        if (oldPath) filePatchIds[oldPath] = id;","        if (newPath) filePatchIds[newPath] = id;","        const status = renamedTo ? \"renamed\" : !newPath ? \"deleted\" : !oldPath ? \"added\" : \"modified\";","        files.push({","            oldPath,","            newPath,","            status,","            patchId: id,","            displayPath: status === \"renamed\" ? renamedDisplayPath(oldPath, newPath) : newPath || oldPath,","        });","    });","    return { filePatchIds, files };","};","","const readStateIdFor = ({ model, selection }) => crypto.createHash(\"sha256\")","    .update(JSON.stringify({","        repoRoot,","        branchName: model.branchName,","        targetRef: model.targetRef,","        selection,","    }))","    .digest(\"hex\");","","const buildReviewContext = async ({ origin, rootPath, searchParams, allowEmpty = false }) => {","    const repositoryState = await inspectRepositoryState({","        repoRoot,","        targetRef: options.target,","    });","    const { model, cacheStatus: modelCacheStatus } = await getVersionModel(repositoryState);","    const selection = normalizeSelection(model, {","        mode: searchParams.get(\"mode\") || undefined,","        from: searchParams.get(\"from\") || undefined,","        to: searchParams.get(\"to\") || undefined,","    });","    const {","        patchText,","        cacheStatus: patchCacheStatus,","    } = await getComparisonPatch({ model, repositoryState, selection });","    const summary = patchSummary(patchText);","    if (summary.empty && !allowEmpty) throw new Error(\"There are no file changes between the selected versions\");","    const patchId = crypto.createHash(\"sha256\").update(patchText).digest(\"hex\").slice(0, 16);","    const { filePatchIds, files } = buildFilePatchData(patchText);","    const readStateId = readStateIdFor({ model, selection });","    const title = `Local MR: ${model.branchName} → ${model.targetRef}`;","    const versionData = clientModel({","        model,","        selection,","        reviewUrl: `${origin}${rootPath}/review`,","        rootUrl: `${origin}${rootPath}`,","        patchId,","        filePatchIds,","        files,","        readStateId,","    });","    const cacheKey = crypto.createHash(\"sha256\")","        .update(options.style)","        .update(\"\\0\")","        .update(options.color)","        .update(\"\\0\")","        .update(patchText)","        .update(\"\\0\")","        .update(JSON.stringify(versionData))","        .digest(\"hex\");","    return {","        cacheKey,","        files,","        model,","        modelCacheStatus,","        patchCacheStatus,","        patchId,","        patchText,","        selection,","        summary,","        title,","        versionData,","    };","};","","const fragmentCacheKey = (patchId, wrapperId) => `${patchId}:${wrapperId}`;","","const renderReviewPage = async (context, { force = false } = {}) => {","    let page = pageCache.get(context.cacheKey);","    const pageCacheStatus = page ? \"hit\" : \"miss\";","    if (page && !force) return { page, pageCacheStatus };","","    const jobKey = force ? `${context.cacheKey}:fragments` : context.cacheKey;","    let renderJob = renderJobs.get(jobKey);","    if (!renderJob) {","        renderJob = (async () => {","            const rendered = renderDiffDocument({","                style: options.style,","                color: options.color,","                title: context.title,","                patchText: context.patchText,","                stylesheet: diff2htmlStylesheet,","            });","            const split = splitRenderedReview(rendered);","            if (split.wrapperIds.length !== context.files.length) {","                throw new Error(","                    `diff2html rendered ${split.wrapperIds.length} files for ${context.files.length} patch sections`,","                );","            }","            split.fragments.forEach((html, wrapperId) => {","                fragmentCache.set(fragmentCacheKey(context.patchId, wrapperId), html);","            });","            const nextPage = {","                html: injectReviewUi({","                    html: split.shellHtml,","                    fragment: reviewFragment,","                    versionData: context.versionData,","                }),","                diffHtml: split.diffHtml,","            };","            pageCache.set(context.cacheKey, nextPage);","            return nextPage;","        })();","        renderJobs.set(jobKey, renderJob);","    }","    try {","        page = await renderJob;","        return { page, pageCacheStatus };","    } finally {","        if (renderJobs.get(jobKey) === renderJob) renderJobs.delete(jobKey);","    }","};","","const setContextCacheHeaders = (response, context, pageCacheStatus) => {","    response.setHeader(\"X-Local-MR-Model-Cache\", context.modelCacheStatus);","    response.setHeader(\"X-Local-MR-Patch-Cache\", context.patchCacheStatus);","    if (pageCacheStatus) response.setHeader(\"X-Local-MR-Page-Cache\", pageCacheStatus);","};","","const loadReadTokens = async (stateId) => {","    try {","        const payload = JSON.parse(await fs.readFile(path.join(readStateDirectory, `${stateId}.json`), \"utf8\"));","        return Array.isArray(payload.tokens)","            ? payload.tokens.filter((token) => typeof token === \"string\" && token.length <= 4096)","            : [];","    } catch {","        return [];","    }","};","","const writeReadTokens = async (stateId, tokens) => {","    if (!/^[a-f0-9]{64}$/.test(stateId)) throw new Error(\"Invalid read state id\");","    if (","        !Array.isArray(tokens)","        || tokens.length > 10_000","        || tokens.some((token) => typeof token !== \"string\" || token.length > 4096)","    ) {","        throw new Error(\"Invalid read state\");","    }","    await fs.mkdir(readStateDirectory, { recursive: true, mode: 0o700 });","    const destination = path.join(readStateDirectory, `${stateId}.json`);","    const temporary = `${destination}.${process.pid}.${crypto.randomBytes(6).toString(\"hex\")}.tmp`;","    try {","        await fs.writeFile(temporary, JSON.stringify({ tokens }), { mode: 0o600, flag: \"wx\" });","        await fs.rename(temporary, destination);","    } finally {","        await fs.rm(temporary, { force: true });","    }","};","","const withReadStateLock = async (stateId, action) => {","    await fs.mkdir(readStateDirectory, { recursive: true, mode: 0o700 });","    const lock = path.join(readStateDirectory, `${stateId}.lock`);","    for (let attempt = 0; attempt < 100; attempt += 1) {","        try {","            await fs.mkdir(lock, { mode: 0o700 });","            try {","                return await action();","            } finally {","                await fs.rm(lock, { recursive: true, force: true });","            }","        } catch (error) {","            if (error.code !== \"EEXIST\") throw error;","            try {","                const metadata = await fs.stat(lock);","                if (Date.now() - metadata.mtimeMs > 30_000) {","                    await fs.rm(lock, { recursive: true, force: true });","                    continue;","                }","            } catch {}","            await new Promise((resolve) => setTimeout(resolve, 10));","        }","    }","    throw new Error(\"Timed out while saving read state\");","};","","const saveReadTokens = (stateId, tokens) => withReadStateLock(","    stateId,","    () => writeReadTokens(stateId, tokens),",");","","const updateReadToken = (stateId, { token, tokenPrefix, read }) => withReadStateLock(","    stateId,","    async () => {","        if (","            typeof token !== \"string\"","            || token.length > 4096","            || typeof tokenPrefix !== \"string\"","            || tokenPrefix.length > 4096","            || typeof read !== \"boolean\"","        ) {","            throw new Error(\"Invalid read state update\");","        }","        const tokens = new Set(await loadReadTokens(stateId));","        [...tokens]","            .filter((candidate) => candidate.startsWith(tokenPrefix))","            .forEach((candidate) => tokens.delete(candidate));","        if (read) tokens.add(token);","        await writeReadTokens(stateId, [...tokens]);","    },",");","","const readJsonBody = async (request) => {","    const chunks = [];","    let bytes = 0;","    for await (const chunk of request) {","        bytes += chunk.length;","        if (bytes > 1024 * 1024) throw new Error(\"Request body is too large\");","        chunks.push(chunk);","    }","    return JSON.parse(Buffer.concat(chunks).toString(\"utf8\") || \"{}\");","};","","const resetIdleTimer = () => {","    clearTimeout(idleTimer);","    idleTimer = setTimeout(() => server.close(), idleMilliseconds);","    idleTimer.unref();","};","","server = http.createServer(async (request, response) => {","    resetIdleTimer();","    const listeningAddress = server.address();","    const origin = `http://127.0.0.1:${listeningAddress.port}`;","    const url = new URL(request.url || \"/\", origin);","    const rootPath = `/${token}`;","    response.setHeader(\"Cache-Control\", \"no-store\");","    response.setHeader(\"Access-Control-Allow-Origin\", \"*\");","    response.setHeader(\"X-Content-Type-Options\", \"nosniff\");","","    if (request.method === \"OPTIONS\") {","        response.statusCode = 204;","        response.setHeader(\"Access-Control-Allow-Headers\", \"Content-Type\");","        response.setHeader(\"Access-Control-Allow-Methods\", \"GET, PUT, PATCH, POST, OPTIONS\");","        response.end();","        return;","    }","","    if (url.pathname === `${rootPath}/health`) {","        response.setHeader(\"Content-Type\", \"application/json; charset=utf-8\");","        response.end(JSON.stringify({ ok: true, pid: process.pid, repoRoot }));","        return;","    }","    if (url.pathname === `${rootPath}/shutdown`) {","        if (request.method !== \"POST\") {","            response.statusCode = 405;","            response.setHeader(\"Allow\", \"POST\");","            response.end(\"Method not allowed\");","            return;","        }","        response.statusCode = 204;","        response.end();","        setImmediate(() => server.close());","        return;","    }","    if (url.pathname === rootPath || url.pathname === `${rootPath}/`) {","        response.statusCode = 302;","        response.setHeader(\"Location\", `${rootPath}/review`);","        response.end();","        return;","    }","    const assetName = url.pathname.startsWith(`${rootPath}/assets/`)","        ? url.pathname.slice(`${rootPath}/assets/`.length)","        : \"\";","    if (assetFiles.has(assetName)) {","        const useBrotli = /(?:^|,)\\s*br(?:\\s*;|\\s*,|$)/i.test(request.headers[\"accept-encoding\"] || \"\");","        const content = await loadAsset(assetName, useBrotli);","        response.setHeader(\"Cache-Control\", \"private, max-age=3600\");","        response.setHeader(\"Content-Type\", \"text/javascript; charset=utf-8\");","        response.setHeader(\"Vary\", \"Accept-Encoding\");","        response.setHeader(\"Content-Length\", content.length);","        if (useBrotli) response.setHeader(\"Content-Encoding\", \"br\");","        response.end(content);","        return;","    }","    const readStateMatch = u