#!/usr/bin/env bash

set -euo pipefail
umask 077

usage() {
    cat <<'EOF'
Usage: local-mr [target-ref] [options]

Render the current working tree as a local, MR-style HTML diff.
The comparison includes committed, staged, unstaged, and untracked changes
without modifying the repository's real Git index. The browser view can switch
between upstream push snapshots and individual/ranged commits.

Arguments:
  target-ref           Target branch/ref (auto-detected when omitted)

Target auto-detection order:
  1. LOCAL_MR_BASE environment variable
  2. branch.<name>.local-mr-target Git config
  3. branch.<name>.vscode-merge-base Git config
  4. origin/HEAD, origin/main, origin/master, main, or master

Options:
  -o, --output FILE    HTML output path
      --no-open        Generate HTML without opening the browser
      --line           Use inline diff layout
      --side           Use side-by-side diff layout (default)
      --light          Force the light color scheme
      --dark           Force the dark color scheme
      --auto-color     Follow the browser color scheme (default)
  -h, --help           Show this help

Examples:
  local-mr
  local-mr origin/main
  local-mr origin/release --dark
  local-mr main --no-open -o /tmp/review.html

Remember a target for the current branch:
  git config branch."$(git branch --show-current)".local-mr-target origin/release
EOF
}

die() {
    printf 'local-mr: %s\n' "$*" >&2
    exit 1
}

print_open_link() {
    local review_url=$1

    if [[ -t 1 ]]; then
        printf 'Open: \033]8;;%s\033\\Open local MR in browser\033]8;;\033\\\n' "$review_url"
    else
        printf 'Open: %s\n' "$review_url"
    fi
}

open_review() {
    local file_path=$1
    local review_url=$2

    if [[ -n "${WSL_DISTRO_NAME:-}" ]] && \
        command -v explorer.exe >/dev/null 2>&1; then
        if explorer.exe "$review_url" >/dev/null 2>&1; then
            return 0
        fi
    fi

    if command -v wslview >/dev/null 2>&1; then
        if wslview "$review_url" >/dev/null 2>&1; then
            return 0
        fi
    fi

    if command -v open >/dev/null 2>&1; then
        if open "$review_url" >/dev/null 2>&1; then
            return 0
        fi
    fi

    if command -v xdg-open >/dev/null 2>&1; then
        if xdg-open "$review_url" >/dev/null 2>&1; then
            return 0
        fi
    fi

    if [[ -n "${WSL_DISTRO_NAME:-}" ]] && \
        command -v wslpath >/dev/null 2>&1 && \
        command -v explorer.exe >/dev/null 2>&1; then
        local windows_path
        windows_path=$(wslpath -w "$file_path" 2>/dev/null || true)
        if [[ -n "$windows_path" ]] && explorer.exe "$windows_path" >/dev/null 2>&1; then
            return 0
        fi
    fi

    return 1
}

target_ref=""
output_file="${LOCAL_MR_OUTPUT:-}"
open_browser=true
style="side"
color_scheme="auto"
script_path=${BASH_SOURCE[0]}
if command -v readlink >/dev/null 2>&1; then
    script_path=$(readlink -f "$script_path" 2>/dev/null || printf '%s' "$script_path")
fi
script_dir=$(cd -- "$(dirname -- "$script_path")" && pwd)
runtime_dir=${LOCAL_MR_RUNTIME_DIR:-}
if [[ -z "$runtime_dir" ]]; then
    for candidate in \
        "$script_dir/../src" \
        "$script_dir/../share/local-mr/src" \
        "$script_dir/../share/local-mr"; do
        if [[ -r "$candidate/version-server.mjs" ]]; then
            runtime_dir=$(cd -- "$candidate" && pwd)
            break
        fi
    done
fi
[[ -n "$runtime_dir" ]] || die "cannot locate the local-mr runtime; reinstall local-mr"
runtime_package_dir=$runtime_dir
if [[ ! -r "$runtime_package_dir/package.json" && -r "$runtime_dir/../package.json" ]]; then
    runtime_package_dir=$(cd -- "$runtime_dir/.." && pwd)
fi
review_ui_fragment="${LOCAL_MR_UI_FRAGMENT:-$runtime_dir/review-ui.html}"
version_server="${LOCAL_MR_VERSION_SERVER:-$runtime_dir/version-server.mjs}"

while (($# > 0)); do
    case "$1" in
        -o|--output)
            (($# >= 2)) || die "$1 requires a file path"
            output_file=$2
            shift 2
            ;;
        --no-open)
            open_browser=false
            shift
            ;;
        --line)
            style="line"
            shift
            ;;
        --side)
            style="side"
            shift
            ;;
        --light)
            color_scheme="light"
            shift
            ;;
        --dark)
            color_scheme="dark"
            shift
            ;;
        --auto-color)
            color_scheme="auto"
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        --)
            shift
            if (($# > 0)); then
                [[ -z "$target_ref" ]] || die "target ref specified more than once"
                target_ref=$1
                shift
            fi
            (($# == 0)) || die "unexpected argument: $1"
            ;;
        -*)
            die "unknown option: $1"
            ;;
        *)
            [[ -z "$target_ref" ]] || die "target ref specified more than once"
            target_ref=$1
            shift
            ;;
    esac
done

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "not inside a Git repository"

invocation_dir=$PWD
repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

branch_name=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || git rev-parse --short HEAD)

if [[ -z "$target_ref" ]]; then
    target_ref=${LOCAL_MR_BASE:-}
fi

if [[ -z "$target_ref" ]]; then
    local_mr_target=$(git config --get "branch.${branch_name}.local-mr-target" 2>/dev/null || true)
    vscode_merge_base=$(git config --get "branch.${branch_name}.vscode-merge-base" 2>/dev/null || true)
    remote_head=$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null || true)
    for candidate in \
        "$local_mr_target" \
        "$vscode_merge_base" \
        "$remote_head" \
        origin/main \
        origin/master \
        main \
        master; do
        [[ -n "$candidate" ]] || continue
        if git rev-parse --verify --quiet "${candidate}^{commit}" >/dev/null; then
            target_ref=$candidate
            break
        fi
    done
fi

[[ -n "$target_ref" ]] || die "cannot detect the target branch; pass one explicitly"
git rev-parse --verify --quiet "${target_ref}^{commit}" >/dev/null || \
    die "target ref does not exist: $target_ref"

repo_name=$(basename "$repo_root")
safe_branch=$(printf '%s' "$branch_name" | tr '/[:space:]' '--')
safe_target=$(printf '%s' "$target_ref" | tr '/[:space:]' '--')

if [[ -z "$output_file" ]]; then
    output_file="${TMPDIR:-/tmp}/local-mr-${repo_name}-${safe_branch}-vs-${safe_target}.html"
elif [[ "$output_file" != /* ]]; then
    output_file="$invocation_dir/$output_file"
fi

output_directory=$(dirname -- "$output_file")
mkdir -p -- "$output_directory"

output_temp=""
server_lock_fd=""
started_server=false
cleanup() {
    if [[ -n "$output_temp" ]]; then
        rm -f -- "$output_temp"
    fi
    if [[ -n "$server_lock_fd" ]] && command -v flock >/dev/null 2>&1; then
        flock -u "$server_lock_fd" 2>/dev/null || true
    fi
}
trap cleanup EXIT

[[ -r "$review_ui_fragment" ]] || die "review UI fragment not found: $review_ui_fragment"
[[ -r "$version_server" ]] || die "version server not found: $version_server"
node_bin=$(command -v node || true)
[[ -n "$node_bin" ]] || die "Node.js is required for the version picker"

server_fingerprint=$(
    sha256sum \
        "$version_server" \
        "$(dirname "$version_server")/version-model.mjs" \
        "$(dirname "$version_server")/review-render.mjs" \
        "$review_ui_fragment" \
        "$runtime_package_dir/package.json" \
        "$runtime_package_dir/node_modules/diff2html/bundles/css/diff2html.min.css" \
        "$runtime_package_dir/node_modules/marked/lib/marked.umd.js" \
        "$runtime_package_dir/node_modules/dompurify/dist/purify.min.js" \
        "$runtime_package_dir/node_modules/mermaid/dist/mermaid.min.js" |
        sha256sum |
        cut -c1-16
)
runtime_key=$(
    printf '%s\0%s\0%s\0%s\0%s' \
        "$repo_root" "$target_ref" "$style" "$color_scheme" "$server_fingerprint" |
        sha256sum |
        cut -c1-16
)
runtime_root="${XDG_RUNTIME_DIR:-${TMPDIR:-/tmp}}/local-mr-${UID}"
server_dir="$runtime_root/$runtime_key"
ready_file="$server_dir/ready.json"
server_log="$server_dir/server.log"
mkdir -p "$server_dir"
chmod 700 "$runtime_root" "$server_dir"
if command -v flock >/dev/null 2>&1; then
    exec {server_lock_fd}>"$server_dir/start.lock"
    flock "$server_lock_fd"
fi

review_url=""
if [[ -s "$ready_file" ]]; then
    review_url=$(
        "$node_bin" -e '
            const fs = require("fs");
            try { process.stdout.write(JSON.parse(fs.readFileSync(process.argv[1], "utf8")).reviewUrl || ""); }
            catch {}
        ' "$ready_file"
    )
    if [[ -n "$review_url" ]]; then
        health_url=${review_url%/review}/health
        if ! curl -fsS --max-time 1 "$health_url" >/dev/null 2>&1; then
            review_url=""
            rm -f "$ready_file"
        fi
    fi
fi

if [[ -z "$review_url" ]]; then
    rm -f "$ready_file"
    server_command=(
        "$node_bin" "$version_server"
        --repo "$repo_root" \
        --target "$target_ref" \
        --style "$style" \
        --color "$color_scheme" \
        --fragment "$review_ui_fragment" \
        --ready "$ready_file" \
        --idle-minutes "${LOCAL_MR_SERVER_IDLE_MINUTES:-480}"
    )
    server_pid=""
    if command -v setsid >/dev/null 2>&1; then
        setsid --fork "${server_command[@]}" </dev/null >"$server_log" 2>&1
    else
        nohup "${server_command[@]}" </dev/null >"$server_log" 2>&1 &
        server_pid=$!
    fi
    for _ in {1..100}; do
        if [[ -s "$ready_file" ]]; then
            break
        fi
        if [[ -n "$server_pid" ]] && ! kill -0 "$server_pid" 2>/dev/null; then
            break
        fi
        sleep 0.05
    done
    if [[ ! -s "$ready_file" ]]; then
        sed -n '1,120p' "$server_log" >&2
        die "version server did not start"
    fi
    review_url=$(
        "$node_bin" -e '
            const fs = require("fs");
            process.stdout.write(JSON.parse(fs.readFileSync(process.argv[1], "utf8")).reviewUrl);
        ' "$ready_file"
    )
    started_server=true
fi

if [[ -n "$server_lock_fd" ]]; then
    flock -u "$server_lock_fd"
    exec {server_lock_fd}>&-
fi

summary_url=${review_url%/review}/summary
summary_json=$(curl -fsS --max-time 60 "$summary_url") || \
    die "could not inspect the working tree; see $server_log"
mapfile -t summary_values < <(
    printf '%s' "$summary_json" | "$node_bin" -e '
        const fs = require("fs");
        const summary = JSON.parse(fs.readFileSync(0, "utf8"));
        console.log(summary.empty ? "true" : "false");
        console.log(summary.shortstat || "");
    '
)
if [[ "${summary_values[0]:-}" == true ]]; then
    if [[ "$started_server" == true ]]; then
        curl -fsS -X POST --max-time 2 "${review_url%/review}/shutdown" >/dev/null 2>&1 || true
    fi
    printf 'No changes between %s and the current working tree.\n' "$target_ref"
    exit 0
fi
shortstat=${summary_values[1]:-}

output_temp=$(mktemp "$output_directory/.local-mr-output.XXXXXXXX")
curl -fsSL --max-time 60 "$review_url" -o "$output_temp" || \
    die "could not render the initial review page; see $server_log"
chmod 600 "$output_temp"
grep -q 'id="local-mr-review-ui"' "$output_temp" || die "review UI fragment was not injected"
grep -q 'id="local-mr-version-data"' "$output_temp" || die "version data was not injected"
mv -f -- "$output_temp" "$output_file"
output_temp=""

printf 'Local MR: %s → %s\n' "$branch_name" "$target_ref"
printf '%s\n' "$shortstat"
printf 'HTML snapshot: %s\n' "$output_file"
printf 'Review: %s\n' "$review_url"

print_open_link "$review_url"

if [[ "$open_browser" == true ]]; then
    if ! open_review "$output_file" "$review_url"; then
        printf 'Could not open the browser automatically; use the link above.\n' >&2
    fi
fi
